<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="gym_class_booking_view_list" model="ir.ui.view">
        <field name="name">gym.class.booking.view.list</field>
        <field name="model">gym.class.booking</field>
        <field name="arch" type="xml">
            <list string="Reservas">
                <field name="partner_id"/>
                <field name="class_id"/>
                <field name="gym_center_id"/>
                <field name="booking_date"/>
                <field name="state"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'cancelled'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="gym_class_booking_view_form" model="ir.ui.view">
        <field name="name">gym.class.booking.view.form</field>
        <field name="model">gym.class.booking</field>
        <field name="arch" type="xml">
            <form string="Reserva">
                <header>
                    <button name="action_cancel"
                            type="object"
                            string="Cancelar"
                            invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="class_id"/>
                        <field name="gym_center_id"/>
                        <field name="booking_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="gym_class_booking_view_search" model="ir.ui.view">
        <field name="name">gym.class.booking.view.search</field>
        <field name="model">gym.class.booking</field>
        <field name="arch" type="xml">
            <search string="Reservas">
                <field name="partner_id"/>
                <field name="class_id"/>
                <field name="gym_center_id"/>
                <filter name="confirmed" string="Confirmadas" domain="[('state', '=', 'confirmed')]"/>
                <separator/>
                <filter name="class_id" string="Clase" context="{'group_by': 'class_id'}"/>
                <filter name="gym_center_id" string="Centro" context="{'group_by': 'gym_center_id'}"/>
                <filter name="state" string="Estado" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="gym_class_booking_action" model="ir.actions.act_window">
        <field name="name">Reservas</field>
        <field name="res_model">gym.class.booking</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
