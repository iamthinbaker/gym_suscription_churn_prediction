<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="gym_promotion_view_list" model="ir.ui.view">
        <field name="name">gym.promotion.view.list</field>
        <field name="model">gym.promotion</field>
        <field name="arch" type="xml">
            <list string="Promociones">
                <field name="name"/>
                <field name="gym_center_id"/>
                <field name="at_risk_only"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="gym_promotion_view_form" model="ir.ui.view">
        <field name="name">gym.promotion.view.form</field>
        <field name="model">gym.promotion</field>
        <field name="arch" type="xml">
            <form string="Promoción">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Título de la promoción"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vigencia">
                            <field name="gym_center_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="active"/>
                        </group>
                        <group string="Segmentación">
                            <field name="at_risk_only"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="gym_promotion_view_search" model="ir.ui.view">
        <field name="name">gym.promotion.view.search</field>
        <field name="model">gym.promotion</field>
        <field name="arch" type="xml">
            <search string="Promociones">
                <field name="name"/>
                <field name="gym_center_id"/>
                <filter name="active" string="Activas" domain="[('active', '=', True)]"/>
                <filter name="at_risk_only" string="Solo en riesgo" domain="[('at_risk_only', '=', True)]"/>
                <separator/>
                <filter name="gym_center_id" string="Centro" context="{'group_by': 'gym_center_id'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="gym_promotion_action" model="ir.actions.act_window">
        <field name="name">Promociones</field>
        <field name="res_model">gym.promotion</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
