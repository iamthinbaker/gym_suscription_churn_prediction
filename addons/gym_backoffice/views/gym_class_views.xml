<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST -->
    <record id="gym_class_view_list" model="ir.ui.view">
        <field name="name">gym.class.view.list</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <list string="Clases">
                <field name="name"/>
                <field name="activity_type"/>
                <field name="gym_center_id"/>
                <field name="trainer_name"/>
                <field name="date_start"/>
                <field name="capacity"/>
                <field name="seats_available" string="Plazas libres"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="gym_class_view_form" model="ir.ui.view">
        <field name="name">gym.class.view.form</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <form string="Clase">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(gym_class_booking_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-calendar-check-o"
                                context="{'search_default_class_id': id}">
                            <field name="seats_taken" widget="statinfo" string="Reservas"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la clase"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Detalles">
                            <field name="activity_type"/>
                            <field name="gym_center_id"/>
                            <field name="trainer_name"/>
                        </group>
                        <group string="Horario y aforo">
                            <field name="date_start"/>
                            <field name="duration"/>
                            <field name="capacity"/>
                            <field name="seats_available"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reservas" name="bookings">
                            <field name="booking_ids" readonly="1">
                                <list>
                                    <field name="partner_id"/>
                                    <field name="booking_date"/>
                                    <field name="state"
                                           decoration-success="state == 'confirmed'"
                                           decoration-danger="state == 'cancelled'"
                                           widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="gym_class_view_search" model="ir.ui.view">
        <field name="name">gym.class.view.search</field>
        <field name="model">gym.class</field>
        <field name="arch" type="xml">
            <search string="Clases">
                <field name="name"/>
                <field name="gym_center_id"/>
                <field name="activity_type"/>
                <filter name="upcoming" string="Próximas"
                        domain="[('date_start', '>=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <separator/>
                <filter name="gym_center_id" string="Centro" context="{'group_by': 'gym_center_id'}"/>
                <filter name="activity_type" string="Actividad" context="{'group_by': 'activity_type'}"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="gym_class_action" model="ir.actions.act_window">
        <field name="name">Clases</field>
        <field name="res_model">gym.class</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_upcoming': 1}</field>
    </record>

</odoo>
