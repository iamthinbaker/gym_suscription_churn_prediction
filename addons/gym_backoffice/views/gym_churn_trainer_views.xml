<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="gym_churn_trainer_view_form" model="ir.ui.view">
        <field name="name">gym.churn.trainer.form</field>
        <field name="model">gym.churn.trainer</field>
        <field name="arch" type="xml">
            <form string="Entrenar modelo de churn">
                <sheet>
                    <group>
                        <field name="trained_at"/>
                        <field name="n_customers"/>
                        <field name="n_churned"/>
                        <field name="churn_rate"/>
                    </group>
                    <group>
                        <field name="model_filename" invisible="1"/>
                        <field name="model_file" filename="model_filename"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_train_model" type="object"
                            string="Entrenar modelo" class="btn-secondary"/>
                    <button name="action_train_and_score" type="object"
                            string="Entrenar y puntuar ahora" class="btn-primary"/>
                    <button string="Cerrar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="gym_churn_trainer_action" model="ir.actions.act_window">
        <field name="name">Entrenar modelo de churn</field>
        <field name="res_model">gym.churn.trainer</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
