<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="gym_churn_model_view_list" model="ir.ui.view">
        <field name="name">gym.churn.model.view.list</field>
        <field name="model">gym.churn.model</field>
        <field name="arch" type="xml">
            <list string="Modelos de churn entrenados">
                <field name="trained_at"/>
                <field name="n_customers"/>
                <field name="n_churned"/>
                <field name="churn_rate"/>
            </list>
        </field>
    </record>

    <record id="gym_churn_model_view_form" model="ir.ui.view">
        <field name="name">gym.churn.model.view.form</field>
        <field name="model">gym.churn.model</field>
        <field name="arch" type="xml">
            <form string="Modelo de churn entrenado">
                <sheet>
                    <group>
                        <field name="trained_at"/>
                        <field name="n_customers"/>
                        <field name="n_churned"/>
                        <field name="churn_rate"/>
                    </group>
                    <group>
                        <field name="model_filename" invisible="1"/>
                        <field name="model_file" filename="model_filename"/>
                    </group>
                    <field name="feature_importance_ids">
                        <list string="Importancia de features" create="false" delete="false">
                            <field name="name"/>
                            <field name="importance_pct" string="Importancia" widget="progressbar"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="gym_churn_model_action" model="ir.actions.act_window">
        <field name="name">Modelos de churn entrenados</field>
        <field name="res_model">gym.churn.model</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
