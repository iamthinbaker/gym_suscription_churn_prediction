<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- === MADRID CENTRO === -->

        <record id="demo_class_yoga_centro" model="gym.class">
            <field name="name">Yoga matinal</field>
            <field name="activity_type">yoga</field>
            <field name="gym_center_id" ref="gym_center_madrid_centro"/>
            <field name="trainer_name">Laura Gómez</field>
            <field name="date_start" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 09:00:00')"/>
            <field name="duration">1.0</field>
            <field name="capacity">15</field>
        </record>

        <record id="demo_class_spinning_centro" model="gym.class">
            <field name="name">Spinning intenso</field>
            <field name="activity_type">spinning</field>
            <field name="gym_center_id" ref="gym_center_madrid_centro"/>
