            <field name="date_start" eval="(datetime.now() + timedelta(days=2)).strftime('%Y-%m-%d 19:00:00')"/>
            <field name="duration">0.75</field>
            <field name="capacity">20</field>
        </record>

        <record id="demo_class_crossfit_centro" model="gym.class">
            <field name="name">CrossFit express</field>
            <field name="activity_type">crossfit</field>
            <field name="gym_center_id" ref="gym_center_madrid_centro"/>
            <field name="trainer_name">Marta Ibáñez</field>
            <field name="date_start" eval="(datetime.now() + timedelta(days=3)).strftime('%Y-%m-%d 18:00:00')"/>
