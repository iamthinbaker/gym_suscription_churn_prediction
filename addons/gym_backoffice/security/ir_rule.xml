<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="gym_center_portal_rule" model="ir.rule">
            <field name="name">Socio: solo su propio centro</field>
            <field name="model_id" ref="model_gym_center"/>
            <field name="domain_force">[('id', '=', user.partner_id.gym_center_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="gym_class_portal_rule" model="ir.rule">
            <field name="name">Socio: solo clases de su centro</field>
            <field name="model_id" ref="model_gym_class"/>
            <field name="domain_force">[('gym_center_id', '=', user.partner_id.gym_center_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="gym_class_booking_portal_rule" model="ir.rule">
            <field name="name">Socio: solo sus propias reservas</field>
            <field name="model_id" ref="model_gym_class_booking"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="gym_promotion_portal_rule" model="ir.rule">
            <field name="name">Socio: promociones globales o de su centro</field>
            <field name="model_id" ref="model_gym_promotion"/>
            <field name="domain_force">['|', ('gym_center_id', '=', False), ('gym_center_id', '=', user.partner_id.gym_center_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

    </data>
</odoo>
