<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_gym_churn_scoring" model="ir.cron">
            <field name="name">GymBaker: puntuar riesgo de churn (diario)</field>
            <field name="model_id" ref="model_gym_customer_health"/>
            <field name="state">code</field>
            <field name="code">model._cron_score_churn()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 00:00:00')"/>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
